rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'createdAt'])
        && data.keys().size() <= 3
        && data.userId == request.auth.uid
        && data.createdAt == request.time
        && (data.get('email', '') is string);
    }
    
    function isValidCalculation(data) {
      return data.keys().hasAll(['mode', 'expression', 'result', 'createdAt'])
        && data.keys().size() == 4
        && data.mode is string && data.mode.size() <= 20
        && data.expression is string && data.expression.size() <= 500
        && data.result is string && data.result.size() <= 500
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      // we do not allow updaing for simplicity right now
      
      match /calculations/{calculationId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(calculationId) && isValidCalculation(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow delete: if isOwner(userId);
      }
    }
  }
}
